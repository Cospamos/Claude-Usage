{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "1.1",
  "description": "Shows Claude usage stats on claude.ai",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage"
  },
  "permissions": ["tabs"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ]
}
